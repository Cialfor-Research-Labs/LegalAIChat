# Core Bedrock config
LEGAL_MODEL_ID=
BEDROCK_MODEL_ID=
AWS_REGION=ap-south-1
BEDROCK_REGION=ap-south-1

# Choose one AWS credential path for local or test environments.
# Production on EC2 should usually rely on the attached IAM role instead.

# Option A: direct credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Option B: shared AWS CLI profile
AWS_PROFILE=

# Option C: assume a role from base credentials/profile
BEDROCK_ASSUME_ROLE_ARN=
BEDROCK_ASSUME_ROLE_SESSION_NAME=lawllm-bedrock-session
BEDROCK_ASSUME_ROLE_EXTERNAL_ID=

# Optional Bedrock client tuning
BEDROCK_CONNECT_TIMEOUT_SEC=10
BEDROCK_READ_TIMEOUT_SEC=30
BEDROCK_MAX_RETRIES=10
