fice/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="16FC19BD" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Title"/></w:pPr><w:r><w:t>LAW LLM User Manual</w:t></w:r></w:p><w:p w14:paraId="607417EA" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="000D64E9"/><w:p w14:paraId="60C644F2" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>1. Introduction</w:t></w:r></w:p><w:p w14:paraId="61ACA290" w14:textId="48FB721E" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:r><w:t xml:space="preserve">LAW LLM is a web-based legal workspace that helps legal </w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:t>professionals</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:t xml:space="preserve"> intake facts, analyze legal issues, draft notices, and manage controlled access for users.</w:t></w:r></w:p><w:p w14:paraId="36E55E68" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:r><w:t>This manual is designed for:</w:t></w:r></w:p><w:p w14:paraId="18638B6F" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Advocates and legal researchers</w:t></w:r></w:p><w:p w14:paraId="3DE8D806" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Internal legal operations users</w:t></w:r></w:p><w:p w14:paraId="2285C422" w14:textId="21F4BEC7" w:rsidR="000D64E9" w:rsidRDefault="00000000" w:rsidP="00F07336"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Admin users managing approvals and access</w:t></w:r></w:p><w:p w14:paraId="00C20454" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:r><w:t>LAW LLM supports legal work. It does not replace professional legal judgment.</w:t></w:r></w:p><w:p w14:paraId="2E2CB1EE" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="000D64E9"/><w:p w14:paraId="03B2BFC6" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>2. System Requirements</w:t></w:r></w:p><w:p w14:paraId="7B73B268" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Modern browser: Chrome, Edge, or Firefox (latest recommended)</w:t></w:r></w:p><w:p w14:paraId="20902D11" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Stable internet connection for AI responses</w:t></w:r></w:p><w:p w14:paraId="561DA8FC" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Approved LAW LLM account</w:t></w:r></w:p><w:p w14:paraId="4AE8B425" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Valid role-based access (User or Admin)</w:t></w:r></w:p><w:p w14:paraId="5C53DF28" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="000D64E9"/><w:p w14:paraId="18A4FB11" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>3. Getting Started</w:t></w:r></w:p><w:p w14:paraId="0C40867B" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>1. Open the LAW LLM web app URL provided by your organization.</w:t></w:r></w:p><w:p w14:paraId="2273E537" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>2. On the login screen, enter your approved email and password.</w:t></w:r></w:p><w:p w14:paraId="532D423A" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>3. If you do not have access yet, select **Request access**.</w:t></w:r></w:p><w:p w14:paraId="0A527D58" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>4. After login, use the left navigation to open Legal Chat, Document tools, and Settings.</w:t></w:r></w:p><w:p w14:paraId="199F5D62" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="000D64E9"/><w:p w14:paraId="11CE25DD" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:r><w:t>What you should see:</w:t></w:r></w:p><w:p w14:paraId="2C8F37AC" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>A dashboard/workspace with navigation and module cards</w:t></w:r></w:p><w:p w14:paraId="0D5797A8" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Theme and session controls in the top area</w:t></w:r></w:p><w:p w14:paraId="7461B729" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="000D64E9"/><w:p w14:paraId="63BC8366" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:lastRenderedPageBreak/><w:t>4. Account Access and Authentication</w:t></w:r></w:p><w:p w14:paraId="5209C249" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>4.1 Sign In</w:t></w:r></w:p><w:p w14:paraId="5B6F4961" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>1. Enter approved email.</w:t></w:r></w:p><w:p w14:paraId="575EE66E" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>2. Enter password.</w:t></w:r></w:p><w:p w14:paraId="118E6EFC" w14:textId="4A1BC9EF" w:rsidR="000D64E9" w:rsidRDefault="00000000" w:rsidP="00F07336"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>3. Click **Sign in**.</w:t></w:r></w:p><w:p w14:paraId="20447F9B" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:r><w:t>If successful:</w:t></w:r></w:p><w:p w14:paraId="7EE030C6" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>You are redirected into the workspace.</w:t></w:r></w:p><w:p w14:paraId="79BC2977" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="000D64E9"/><w:p w14:paraId="428FBF14" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>4.2 Forgot Password</w:t></w:r></w:p><w:p w14:paraId="1FA23E0E" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>1. Enter your email on the login page.</w:t></w:r></w:p><w:p w14:paraId="2E33661F" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>2. Click **Forgot password?**</w:t></w:r></w:p><w:p w14:paraId="04E16E3C" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>3. Check email for a setup/reset link.</w:t></w:r></w:p><w:p w14:paraId="7F2C1D55" w14:textId="1BF41EBA" w:rsidR="000D64E9" w:rsidRDefault="00000000" w:rsidP="00F07336"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>4. Open link and set a new password.</w:t></w:r></w:p><w:p w14:paraId="5A6E3991" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:r><w:t>Common mistakes to avoid:</w:t></w:r></w:p><w:p w14:paraId="51A35AE6" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Entering a different email than the approved account</w:t></w:r></w:p><w:p w14:paraId="02E300A0" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>Using an expired link</w:t></w:r></w:p><w:p w14:paraId="599BB026" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="000D64E9"/><w:p w14:paraId="44C17A39" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>4.3 Request Access</w:t></w:r></w:p><w:p w14:paraId="4D7AB413" w14:textId="2B52F963" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>1. Click</w:t></w:r><w:r w:rsidRPr="00F07336"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve"> Request access </w:t></w:r><w:r><w:t>on login.</w:t></w:r></w:p><w:p w14:paraId="775B0ECC" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>2. Fill first name, last name, email, organization, and use case.</w:t></w:r></w:p><w:p w14:paraId="7B539667" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>3. Submit request.</w:t></w:r></w:p><w:p w14:paraId="50BDD5A4" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="ListNumber"/></w:pPr><w:r><w:t>4. Wait for admin approval.</w:t></w:r></w:p><w:p w14:paraId="1DB9E7E5" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="000D64E9"/><w:p w14:paraId="00020494" w14:textId="77777777" w:rsidR="000D64E9" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>4.4 Set Password (First-Time Setup)<